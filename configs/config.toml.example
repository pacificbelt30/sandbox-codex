# =============================================================================
# codex-dock configuration file
#
#   Location : ~/.config/codex-dock/config.toml
#   Format   : TOML
#   Purpose  : change the default value of command-line flags so you don't have
#              to repeat them on every command.
#
# Precedence (highest first):
#   1. command-line flag        (e.g. --image)
#   2. environment variable     (CODEX_DOCK_*)
#   3. this config file
#   4. built-in default
#
# Every key below is OPTIONAL. Delete a line to fall back to the built-in
# default. Lines starting with `#` are comments / disabled examples.
# =============================================================================


# -----------------------------------------------------------------------------
# Global defaults
# -----------------------------------------------------------------------------

# Docker image used for sandbox (worker) containers.   flag: --image / -i
default_image = "codex-dock:latest"

# Docker image used for the auth proxy container.      (proxy build / run)
proxy_image = "codex-dock-proxy:latest"

# Auth-proxy token lifetime, in seconds.               flag: --token-ttl
# Shorter = safer if a token leaks. 1800 = 30 min, 3600 = 1 h.
default_token_ttl = 3600

# Name of the Docker egress network the auth proxy attaches to.
#                                                      env: CODEX_DOCK_NETWORK_NAME
# Workers no longer share a single network: each worker gets its own Internal
# network (dock-net-w-<name>) shared only with the proxy, so worker↔worker,
# worker→host, and worker→internet are all blocked by Docker (no iptables/sudo).
network_name = "dock-net-proxy"

# Print extra operational logs by default.             flag: --verbose / -v
verbose = false

# Print debug logs by default.                         flag: --debug
debug = false


# -----------------------------------------------------------------------------
# [run] — defaults specific to `codex-dock run`
# -----------------------------------------------------------------------------
[run]

# Image for `run` only. If unset, the global `default_image` is used.
image = "codex-dock:latest"

# Token TTL for `run` only. If unset, the global `default_token_ttl` is used.
token_ttl = 3600

# Which user the agent runs as inside the container.   flag: --user
#   current        host user's uid:gid (default)
#   codex          the image's codex user (1001:1001)
#   dir            owner of the project directory
#   ""             image default user
#   <uid>[:<gid>]  explicit, e.g. "1000:1000"
user = "current"

# Codex CLI approval mode.                             flag: --approval-mode
#   suggest | auto-edit | full-auto | danger
approval_mode = "suggest"


# -----------------------------------------------------------------------------
# [proxy] — defaults for the auth proxy / router
#
# Isolation is enforced by Docker networks, not iptables — there is no host
# firewall to configure and `codex-dock` never calls sudo. The proxy container
# is the only egress path: workers reach it over their per-worker Internal
# network and route all general traffic (git/npm/pip/curl) through its built-in
# HTTP CONNECT forward proxy, while OpenAI/Anthropic API calls use its
# credential-injecting reverse-proxy routes.
# -----------------------------------------------------------------------------
[proxy]

# Auth Proxy URL reachable from worker containers (Docker DNS name + data-plane
# port).                                               flag: --proxy-container-url
# The legacy key `firewall.proxy_container_url` is still honored for now.
container_url = "http://codex-auth-proxy:18080"

# Optionally restrict the forward proxy to a domain allowlist (and subdomains).
# An empty/omitted list allows all destinations.       flag: --forward-allow-domain
#
# Example: only allow common package registries and source hosts.
# forward_allow_domains = ["github.com", "registry.npmjs.org", "pypi.org", "files.pythonhosted.org"]
