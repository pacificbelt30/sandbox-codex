# codex-dock configuration file
# Place at ~/.config/codex-dock/config.toml

# Default Docker image for sandbox containers
default_image = "codex-dock:latest"

# Default Docker image for the auth proxy container
proxy_image = "codex-dock-proxy:latest"

# Default token TTL in seconds
default_token_ttl = 3600

# Docker network name
network_name = "dock-net"

# Enable verbose output by default
verbose = false

# Enable debug output by default
debug = false

[run]
# Default image for `codex-dock run --image`
# If unset, `default_image` is used.
image = "codex-dock:latest"

# Default token TTL for `codex-dock run --token-ttl`
# If unset, `default_token_ttl` is used.
token_ttl = 3600

# Default user mode for `codex-dock run --user`
# current | codex | dir | "" | <uid>[:<gid>]
user = "current"

# Default approval mode for `codex-dock run --approval-mode`
# suggest | auto-edit | full-auto | danger
approval_mode = "suggest"

[firewall]
# Default Auth Proxy URL reachable from worker containers.
# Used by `codex-dock run` and `codex-dock firewall create` when
# --proxy-container-url is not given.
proxy_container_url = "http://codex-auth-proxy:18080"

# Extra IP:PORT destinations to always allow through the dock-net firewall.
# Equivalent to passing --allow-host repeatedly. IP literals only
# (IPv6 as "[::1]:PORT"). A CLI --allow-host overrides this list.
# allow_hosts = ["203.0.113.10:5000", "198.51.100.7:443"]
